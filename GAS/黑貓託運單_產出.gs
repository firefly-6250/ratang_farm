/**
 * 將「李子訂單」工作表資料，轉換成「黑貓宅急便託運單」格式。
 * 三種水果分開出貨，分別寫入三張工作表：
 *   黑貓託運單-紅肉李 / 黑貓託運單-蜜李 / 黑貓託運單-西瓜李
 *
 * 使用方式：
 *   1. 開啟試算表 → 擴充功能 → Apps Script，貼上本檔內容。
 *   2. 執行 產出黑貓託運單()，或重新整理試算表後從上方「黑貓宅急便」選單執行。
 *
 * 主要邏輯：
 *   - 「收件者不同人＝是」→ 收件人＝收件人姓名/收件人電話欄；否則用訂購人本人。
 *   - 收件地址永遠取「收件地址」欄。
 *   - 依訂購內容把訂單拆進對應水果的工作表，備註只放該水果的品項。
 *   - 件數＝該水果所有品項的盒數加總後，每 3 盒算 1 件（無條件進位）：
 *     1-3盒=1件、4-6盒=2件、7-9盒=3件、10-12盒=4件。
 *   - 已出貨判斷：對應水果的「○○託運單號」欄有值＝已出貨，該水果不再產出。
 *   - 排除收件方式含「自取」的訂單。
 *   - 貨到付款的代收金額（全額訂單金額）只填在訂單中第一個出現的水果（紅肉李>蜜李>西瓜李）。
 */

// ===== 可自行調整的預設值 =====
const CFG = {
  來源工作表: '水蜜桃訂單',

  預設件數: 1,          // 解析不到盒數時的後備值（正常情況會依品項自動加總）
  每件盒數: 3,          // 件數換算：每 3 盒算 1 件（1-3盒=1件、4-6盒=2件、7-9盒=3件…）
  預設品名: '4',        // 品名(詳參數表)：全部填參數表代碼 4
  預設溫層: '2',      // 李子為生鮮，預設冷藏（依參數表填：1常溫/2冷藏/3冷凍）
  預設尺寸: '2',      // 依參數表填（60cm/90cm/120cm/150cm）
  預設希望配達時間: '4',  // 留空＝不指定（依參數表填1:13點前,2:14:00~18:00,4:不指定）
  出貨日期: '', // 預設今天；不需要可改成 ''

  // 是否只匯出已對帳/已付款的訂單。true＝只匯出狀態含「對帳成功」的訂單。
  只匯出已付款: false,
};

// 黑貓託運單的標題列（順序固定，請勿任意更動）
const 託運單標題 = [
  '收件人姓名', '收件人電話', '收件人手機', '收件人地址', '代收金額或到付',
  '件數', '品名(詳參數表)', '備註', '訂單編號', '希望配達時間(詳參數表)',
  '出貨日期(YYYY/MM/DD)', '預定配達日期(YYYY/MM/DD)', '溫層(詳參數表)', '尺寸(詳參數表)', '付款狀況'
];

// 三種水果分開出貨：各自的輸出工作表，以及判斷「已出貨」用的託運單號欄。
// 代收金額（貨到付款）只填在訂單中「第一個出現的水果」，順序即此陣列順序。
// 比對關鍵字：品項字串含此關鍵字才算這種水果；留空('') = 來源表所有品項都算
//（水蜜桃訂單的訂購內容是「10粒裝 一盒×1」，不含水果名稱，所以必須留空）。
const 水果清單 = [
  //{ 名稱: '紅肉李', 工作表: '黑貓託運單-紅肉李', 託運單號欄: '紅肉李託運單號', 比對關鍵字: '紅肉李' },
  //{ 名稱: '蜜李',   工作表: '黑貓託運單-蜜李',   託運單號欄: '蜜李託運單號',   比對關鍵字: '蜜李' },
  //{ 名稱: '西瓜李', 工作表: '黑貓託運單-西瓜李', 託運單號欄: '西瓜李託運單號', 比對關鍵字: '西瓜李' },
  { 名稱: '水蜜桃', 工作表: '黑貓託運單-水蜜桃', 託運單號欄: '託運單號', 比對關鍵字: '' },
];

/** 品項是否屬於此水果：無比對關鍵字＝全部符合（單一水果的訂單表用） */
function 屬於水果(f, 品項字串) {
  return !f.比對關鍵字 || 品項字串.indexOf(f.比對關鍵字) !== -1;
}

/** 將電話正規化成 09xxxxxxxx：去除符號、+886 還原成 0、補回前導 0 */
function 正規化電話(raw) {
  let s = String(raw).replace(/[^0-9]/g, ''); // 只保留數字
  if (s.indexOf('886') === 0) s = '0' + s.slice(3); // +886986120567 → 0986120567
  if (s.length === 9 && s.charAt(0) === '9') s = '0' + s; // 漏掉前導 0 的手機
  return s;
}

/** 從單一品項字串解析箱數，例：「紅肉李 5斤裝(小箱)×4」→ 4；找不到數量則回 CFG.預設件數 */
function 解析箱數(品項字串) {
  const m = String(品項字串).match(/[×xX*]\s*(\d+)/); // 容許全形 × 或半形 x X *
  return m ? Number(m[1]) : CFG.預設件數;
}

/** 在試算表開啟時加入自訂選單 */
function onOpen() {
  SpreadsheetApp.getUi()
    .createMenu('黑貓宅急便')
    .addItem('📝 1.列出需出貨的名單', '產出黑貓託運單')
    //.addItem('🚚 2.匯出黑貓託運Excel檔-紅肉李', 'exportHongrouli')
    //.addItem('🚚 2.匯出黑貓託運Excel檔-蜜李', 'exportMili')
    //.addItem('🚚 2.匯出黑貓託運Excel檔-西瓜李', 'exportXiguali')
    .addItem('🚚 2.匯出黑貓託運Excel檔-水蜜桃', 'exportPeach')
    .addToUi();
}

/** 主流程 */
function 產出黑貓託運單() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const src = ss.getSheetByName(CFG.來源工作表);
  if (!src) throw new Error('找不到工作表：' + CFG.來源工作表);

  const data = src.getDataRange().getValues();
  // 標題在第 2 列、實際訂單資料從第 3 列開始
  if (data.length < 3) throw new Error('「' + CFG.來源工作表 + '」沒有訂單資料。');

  // 以「標題文字」找欄位索引（標題在第 2 列），欄位順序變動也不會出錯
  const header = data[1].map(h => String(h).trim());
  const col = name => {
    const i = header.indexOf(name);
    if (i === -1) throw new Error('來源缺少欄位：' + name);
    return i;
  };
  const optCol = name => header.indexOf(name); // 找不到回傳 -1
  const c = {
    訂單編號: col('訂單編號'),
    姓名:    col('姓名'),
    電話:    col('電話'),
    收件者不同人: col('收件者不同人'),
    收件人姓名: col('收件人姓名'),
    收件人電話: col('收件人電話'),
    收件地址: col('收件地址'),
    備註:    col('備註'),
    訂購內容: col('訂購內容'),
    訂單金額: col('訂單金額'),
    狀態:    col('狀態'),
    收件方式: optCol('收件方式'), // 可能不存在
    配送時段: optCol('配送時段'), // 可能不存在
    款項與出貨狀況: optCol('款項與出貨狀況'), // 可能不存在
  };
  // 各水果「已出貨」判斷欄（該水果託運單號有值＝已出貨），可能尚未建立
  水果清單.forEach(f => { f._號欄 = optCol(f.託運單號欄); });

  // 每種水果各一個收集籃
  const buckets = {};
  水果清單.forEach(f => { buckets[f.名稱] = []; });

  for (let r = 2; r < data.length; r++) { // 從第 3 列（索引 2）開始讀資料
    const row = data[r];
    if (!String(row[c.訂單編號]).trim()) continue; // 略過空白列

    // 排除收件方式為「埔里自取」（自取）的訂單，不需託運
    const 收件方式 = c.收件方式 === -1 ? '' : String(row[c.收件方式]).trim();
    if (收件方式.indexOf('自取') !== -1) continue;

    const 狀態 = String(row[c.狀態]).trim();
    if (CFG.只匯出已付款 && 狀態.indexOf('對帳成功') === -1 && 狀態.indexOf('已付款') === -1) {
      continue;
    }

    // 收件人資訊（同一訂單的三種水果共用）
    const 不同人 = String(row[c.收件者不同人]).trim() === '是';
    const 收件人姓名 = 不同人 ? String(row[c.收件人姓名]).trim() : String(row[c.姓名]).trim();
    const 電話號碼 = 正規化電話(不同人 ? row[c.收件人電話] : row[c.電話]);
    // 09xx 開頭的 10 碼視為手機，填手機欄；其餘（市話等）填電話欄
    const 是手機 = /^09\d{8}$/.test(電話號碼);
    const 手機欄 = 是手機 ? 電話號碼 : '';
    const 電話欄 = 是手機 ? '' : 電話號碼;
    const 收件地址 = String(row[c.收件地址]).trim();
    const 原備註 = String(row[c.備註]).trim();
    // 希望配達時間取「配送時段」欄；無此欄則用預設值
    const 希望配達時間 = c.配送時段 === -1 ? CFG.預設希望配達時間 : String(row[c.配送時段]).trim();
    // 付款狀況取「款項與出貨狀況」欄
    const 付款狀況 = c.款項與出貨狀況 === -1 ? '' : String(row[c.款項與出貨狀況]).trim();

    // 解析訂購內容，以逗號拆成各品項（例：「紅肉李 5斤裝(小箱)×1, 蜜李 8斤裝(中箱)×1」）
    const 品項 = String(row[c.訂購內容]).split(/[,，]/).map(s => s.trim()).filter(String);

    // 貨到付款的全額代收，只給「第一個出現的水果」(紅肉李>蜜李>西瓜李)
    const 是貨到付款 = 狀態.indexOf('貨到付款') !== -1;
    const 首要水果 = 水果清單.find(f => 品項.some(it => 屬於水果(f, it)));

    // 把訂單依水果拆進各自的籃子
    水果清單.forEach(f => {
      const 該水果品項 = 品項.filter(it => 屬於水果(f, it));
      if (該水果品項.length === 0) return; // 此訂單沒有這種水果

      // 該水果已出貨（託運單號已有值）則不再產出
      if (f._號欄 !== -1 && String(row[f._號欄]).trim()) return;

      // 先加總該水果所有品項的盒數（例：×4 + ×1 ＝ 5 盒），
      // 再依 CFG.每件盒數 換算件數（每 3 盒算 1 件，無條件進位：5 盒 → 2 件）
      const 總盒數 = 該水果品項.reduce((sum, it) => sum + 解析箱數(it), 0);
      const 件數 = Math.max(1, Math.ceil(總盒數 / CFG.每件盒數));

      const 代收金額 = (是貨到付款 && 首要水果 && f.名稱 === 首要水果.名稱) ? row[c.訂單金額] : '';
      const 備註內容 = [該水果品項.join(', '), 原備註].filter(String).join(' ');

      buckets[f.名稱].push([
        收件人姓名,                 // 收件人姓名
        電話欄,                     // 收件人電話（非 09xx 的市話/其他號碼）
        手機欄,                     // 收件人手機（09xx 開頭）
        收件地址,                   // 收件人地址
        代收金額,                   // 代收金額或到付（貨到付款的第一個水果＝訂單金額，其餘留空）
        件數,                       // 件數：盒數加總後每 3 盒算 1 件（無條件進位）
        CFG.預設品名,               // 品名(詳參數表)：固定填 4
        備註內容,                   // 備註：該水果品項（含原備註）
        String(row[c.訂單編號]).trim(), // 訂單編號
        希望配達時間,               // 希望配達時間(詳參數表)：取自「配送時段」
        CFG.出貨日期,               // 出貨日期
        '',                         // 預定配達日期
        CFG.預設溫層,               // 溫層
        CFG.預設尺寸,               // 尺寸
        付款狀況,                   // 付款狀況：取自「款項與出貨狀況」
      ]);
    });
  }

  // 分別寫入三張工作表
  const 訊息 = 水果清單.map(f => {
    寫入託運單(ss, f.工作表, buckets[f.名稱]);
    return f.名稱 + ' ' + buckets[f.名稱].length + ' 筆';
  });
  SpreadsheetApp.getActive().toast('已產出 — ' + 訊息.join('、'), '黑貓託運單', 6);
}

/** 將託運單資料寫入指定工作表（不存在則建立，並清空、設定格式） */
function 寫入託運單(ss, sheetName, rows) {
  let dst = ss.getSheetByName(sheetName);
  if (!dst) dst = ss.insertSheet(sheetName);
  dst.clearContents();
  // 收件人電話(第2欄)、收件人手機(第3欄)設為純文字，避免開頭的 0 被吃掉
  dst.getRange(1, 2, dst.getMaxRows(), 2).setNumberFormat('@');
  dst.getRange(1, 1, 1, 託運單標題.length).setValues([託運單標題]);
  if (rows.length) {
    dst.getRange(2, 1, rows.length, 託運單標題.length).setValues(rows);
  }
  dst.setFrozenRows(1);
  dst.autoResizeColumns(1, 託運單標題.length);
}